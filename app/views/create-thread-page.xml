<Page navigatingTo="onNavigatingTo" class="page">
  <ActionBar title="New Thread" class="navy-bar">
    <NavigationButton text="Cancel" tap="onCancel" />
    <ActionItem text="Post" tap="onPost" ios.position="right" />
  </ActionBar>

  <ScrollView>
    <StackLayout padding="16">
      <!-- Category Selection -->
      <Label text="Category" class="section-header" margin-bottom="8" />
      <GridLayout columns="*, *, *, *" rows="auto" margin-bottom="16">
        <Button col="0" text="Question" tap="onSelectCategory" id="cat-question" class="category-select-btn" />
        <Button col="1" text="Idea" tap="onSelectCategory" id="cat-idea" class="category-select-btn" />
        <Button col="2" text="Announce" tap="onSelectCategory" id="cat-announcement" class="category-select-btn" />
        <Button col="3" text="General" tap="onSelectCategory" id="cat-general" class="category-select-btn active" />
      </GridLayout>

      <!-- Title -->
      <Label text="Title" class="section-header" margin-bottom="4" />
      <TextField id="titleInput" hint="What's your thread about?" class="input-field" />

      <!-- Message -->
      <Label text="Message" class="section-header" margin-bottom="4" />
      <TextView id="messageInput" hint="Share your thoughts, questions, or ideas..." class="text-area" />

      <!-- Post Button -->
      <Button text="Post Thread" tap="onPost" class="btn-primary" margin-top="16" />

      <ActivityIndicator id="loading" busy="false" color="#627d98" margin-top="16" />
      <Label id="error" text="" color="#ff6b6b" font-size="13" text-wrap="true" margin-top="8" />
    </StackLayout>
  </ScrollView>
</Page>
