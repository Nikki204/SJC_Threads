<Page navigatingTo="onNavigatingTo" class="page ns-light">
  <ActionBar title="SJC Threads" class="navy-bar">
    <ActionItem text="Profile" tap="onGoToProfile" ios.position="left" android.position="actionBar" />
    <ActionItem text="Logout" tap="onLogout" ios.position="right" android.position="actionBar" />
  </ActionBar>

  <GridLayout rows="auto, auto, *, auto">
    <StackLayout row="0" class="home-header">
      <Label text="{{ headerTitle }}" class="home-header-title" />
      <Label text="Browse below. New here? Open the Welcome thread for a quick tour." class="home-header-subtitle" margin-top="6" textWrap="true" />

      <StackLayout class="compose-card">
        <Button text="Start a new thread…" tap="onNewThread" class="compose-btn" />
      </StackLayout>
    </StackLayout>

    <ScrollView row="1" orientation="horizontal" class="bg-white" padding="8">
      <StackLayout orientation="horizontal">
        <Button text="All" tap="onFilterCategory" class="category-filter-btn active" id="filter-all" />
        <Button text="Questions" tap="onFilterCategory" class="category-filter-btn" id="filter-question" />
        <Button text="Ideas" tap="onFilterCategory" class="category-filter-btn" id="filter-idea" />
        <Button text="Announcements" tap="onFilterCategory" class="category-filter-btn" id="filter-announcement" />
        <Button text="General" tap="onFilterCategory" class="category-filter-btn" id="filter-general" />
      </StackLayout>
    </ScrollView>

    <ListView row="2" items="{{ threads }}" itemTap="onThreadTap" class="thread-list" separatorColor="#e9ecef">
      <ListView.itemTemplate>
        <StackLayout class="thread-card" tap="onThreadTap">
          <GridLayout columns="auto, *, auto" rows="auto">
            <Label col="0" text="{{ category }}" class="category-badge" textTransform="capitalize" />
            <Label col="2" text="{{ timeAgo }}" class="thread-meta" />
          </GridLayout>

          <Label text="{{ title }}" class="thread-title" textWrap="true" margin-top="8" />

          <Label text="{{ messagePreview }}" class="thread-message" textWrap="true" />

          <GridLayout columns="auto, *" rows="auto" margin-top="10">
            <Label col="0" text="{{ authorName }}" class="thread-author" font-size="13" />
            <Label col="1" text="{{ threadStats }}" class="thread-meta" horizontalAlignment="right" />
          </GridLayout>
        </StackLayout>
      </ListView.itemTemplate>
    </ListView>

    <StackLayout row="2" id="emptyState" visibility="collapsed" class="empty-state">
      <Label text="💬" class="empty-icon" />
      <Label text="No threads yet" class="empty-title" />
      <Label text="Be the first to start a discussion!" class="empty-text" />
    </StackLayout>

    <ActivityIndicator row="2" id="loading" busy="false" class="loading-spinner" />

    <GridLayout row="3" rows="*" columns="*">
      <Button text="+" tap="onNewThread" class="fab" horizontalAlignment="right" verticalAlignment="bottom" margin="16" rowSpan="2" />
    </GridLayout>
  </GridLayout>
</Page>
