<Page navigatingTo="onNavigatingTo" class="page ns-light">
  <ScrollView>
    <StackLayout class="auth-container">
      <Label text="SJC" class="brand-mark" horizontalAlignment="center" />
      <Label text="SJC Threads" class="auth-title" />
      <Label text="Student Discussion Forum" class="auth-subtitle" />

      <TextField id="email" hint="Email" keyboardType="email" class="auth-input" autocorrect="false" autocapitalizationType="none" />
      <TextField id="password" hint="Password" secure="true" class="auth-input" />

      <Button text="Sign In" tap="{{ onSignIn }}" class="auth-btn" />
      <Button text="Create Account" tap="{{ onGoToRegister }}" class="auth-secondary-btn" />

      <Label text="Forgot password?" tap="{{ onForgotPassword }}" class="auth-link" />
      <ActivityIndicator id="loading" busy="false" color="#bcccdc" margin-top="16" />
      <Label id="error" text="" color="#ff6b6b" font-size="13" text-wrap="true" margin-top="8" text-align="center" />
    </StackLayout>
  </ScrollView>
</Page>
